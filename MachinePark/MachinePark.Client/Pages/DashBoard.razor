@page "/"
@using MachinePark.Client.Components

<PageTitle>MachinePark Dashboard</PageTitle>

<h1>Dashboard</h1>
<p>Overview of your industrial IoT devices.</p>

<div class="container mt-4">

    <div class="row">

        <!-- Left card (4 columns) -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    Statistics
                </div>

                <div class="card-body">
                    Running machines: 3<br />
                    Stopped machines: 2
                </div>
            </div>
        </div>

        <!-- Right card (8 columns) -->
        <div class="col-md-8">
            <MachineTableCard Machines="_machines"/>
        </div>
    </div>

</div>
@code {
    [Inject]
    public MachineState State { get; set; } = null!;

    private List<Machine> _machines = [];

    protected override void OnInitialized()
    {
        _machines = [
            new Machine { Name = "Machine A", LastData = "Running", IsOnline = true },
            new Machine { Name = "Machine B", LastData = "Stopped", IsOnline = false  },
            new Machine { Name = "Machine C", LastData = "Stopped", IsOnline = false  }
            ];

        UpdateCount();
    }

    private void UpdateCount() => State.SetCount(_machines.Count);
}