@page "/"
@* @rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false)) *@
@using MachinePark.Client.Components
@using MachinePark.Client.Services
@using MachinePark.State
@inject PersistentComponentState ApplicationState

<PageTitle>MachinePark Dashboard</PageTitle>

<h1 class="h3">Dashboard</h1>
<h6 class="text-muted">Overview of your industrial IoT devices.</h6>

<div class="container mt-4">

    <div class="row">
        <!-- Left card (4 columns) -->
        <div class="col-md-4">
            <StatisticsCard />
        </div>

        <!-- Right card (8 columns) -->
        <div class="col-md-8">
            @if(Machines is not null)
            {
                <MachineTableCard Machines="Machines" OnToggleOnlineState="ToggleOnlineState" OnAddMachine="HandleAddMachine" OnDeleteMachine="HandleDeleteMachine" OnUploadMachineData="HandleUploadData" />
            }
        </div>
    </div>

</div>
@code {

    [Inject]
    private MachineApi Api { get; set; } = null!;

    [Inject]
    private MachineState State { get; set; } = null!;

    [PersistentState]
    public List<Machine>? Machines { get; set; }

    protected async override Task OnInitializedAsync()
    {
        if (Machines is null)
        {
            await FetchMachines();
        }
        UpdateCount();
    }

    private async Task ToggleOnlineState(Machine machine)
    {
        await (machine.IsOnline ? Api.StopMachineAsync(machine.Id) : Api.StartMachineAsync(machine.Id));
        await FetchMachines();
    }

    private async Task HandleAddMachine(AddMachine machine)
    {
        Machine newMachine = new() {
                Name = machine.Name,
                IsOnline = machine.IsOnline,
                LastUpdated = DateTime.Now,
                LastData = machine.IsOnline ? "Machine created and running" : "Machine created"
            };
        await Api.AddMachineAsync(newMachine);
        await FetchMachines();
    }

    private async Task HandleDeleteMachine(Machine machine)
    {
        await Api.RemoveMachineAsync(machine.Id);
        await FetchMachines();
    }

    private async Task HandleUploadData(UploadMachineData machineData)
    {
        await Api.UpdateMachineDataAsync(machineData);
        await FetchMachines();
    }

    private async Task FetchMachines()
    {
        Machines = await Api.GetMachinesAsync();
        UpdateCount();
    }

    private void UpdateCount() => State.SetCount(Machines);
}