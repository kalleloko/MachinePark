
@inject IJSRuntime JS

<div class="modal fade" id="uploadMachineDataModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <EditForm Model="model" OnValidSubmit="UploadData">

                <div class="modal-header">
                    <h5 class="modal-title">Send to machine "@Machine?.Name"</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="mb-3">
                        <label for="new-machine-name" class="form-label">Data</label>
                        <InputText id="new-machine-name"
                                   class="form-control"
                                   @bind-Value="model.Data"
                                   placeholder="Enter new data..." />
                    </div>
                </div>  

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Send</button>
                </div>

            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<UploadMachineData> OnUpload { get; set; }

    [Parameter]
    public Machine? Machine { get; set; }

    private UploadMachineData model = new();

    private async Task UploadData()
    {
        if (Machine is null)
        {
            return;
        }
        if(OnUpload.HasDelegate) {
            model.Id = Machine.Id;
            await OnUpload.InvokeAsync(model);
        }
        model = new UploadMachineData();
        await JS.InvokeVoidAsync("hideModal", "uploadMachineDataModal");
    }

    protected override void OnParametersSet()
    {
        model = new UploadMachineData();
    }

}