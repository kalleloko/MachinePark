
@inject IJSRuntime JS

<div class="modal fade" id="uploadMachineDataModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <EditForm Model="model" OnValidSubmit="UploadData">

                <div class="modal-header">
                    <h5 class="modal-title">Send to machine "@Machine?.Name"</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="mb-3 input-group">
                        <label class="input-group-text" for="machine-data">
                            Value
                        </label>
                        <InputNumber id="new-machine-data"
                                     class="form-control text-end"
                                   @bind-Value="model.Data"
                                   step="0.1"/>
                        <span class="input-group-text" inputmode="decimal">@Machine?.Unit</span>
                    </div>
                </div>  

                <div class="modal-footer">
                    @if (string.IsNullOrWhiteSpace(ErrorMessage))
                    {
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Send</button>
                    }
                    else
                    {
                        <div class="alert alert-danger">@ErrorMessage <a class="btn btn-secondary" data-bs-dismiss="modal">&times; Close</a></div>
                    }
                </div>

            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<UploadMachineData> OnUpload { get; set; }

    [Parameter]
    public Machine? Machine { get; set; }

    private UploadMachineData model = new();

    private Guid? _loadedMachineId;
    
    public string? ErrorMessage { get; set; }


    protected override void OnParametersSet()
    {
        if (Machine is null)
        {
            return;
        }

        if (_loadedMachineId == Machine.Id)
        {
            return;
        }

        _loadedMachineId = Machine.Id;

        model = new UploadMachineData
        {
            Id = Machine.Id,
            Data = Math.Round(Machine.LastData, 1)
        };
    }

    private async Task UploadData()
    {
        if (Machine is null)
        {
            return;
        }
        try {
            if(OnUpload.HasDelegate) {
                model.Id = Machine.Id;
                await OnUpload.InvokeAsync(model);
            }
            await JS.InvokeVoidAsync("hideModal", "uploadMachineDataModal");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Kunde inte uppdatera maskinen: {ex.Message}";
        }
    }

}