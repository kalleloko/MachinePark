@inject IJSRuntime JS

<div class="modal fade" id="addMachineModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <EditForm Model="model" OnValidSubmit="AddMachine">

                <div class="modal-header">
                    <h5 class="modal-title">Add machine</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="mb-3">
                        <label for="new-machine-name" class="form-label">Machine name</label>
                        <InputText id="new-machine-name"
                                   class="form-control"
                                   @bind-Value="model.Name"
                                   placeholder="Machine name" />
                    </div>
                    <div class="mb-3">
                        <InputSelect id="new-machine-type"
                                     class="form-select"
                                     @bind-Value="model.Type">
                            <option value="">Select machine type...</option>
                            @foreach (var type in Enum.GetValues<MachineType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="form-check mb-3">
                        <InputCheckbox id="new-machine-online-state"
                                       class="form-check-input"
                                       @bind-Value="model.IsOnline" />
                        <label for="new-machine-online-state" class="form-check-label">Connect the machine when creating</label>
                    </div>
                </div>

                <div class="modal-footer">
                    @if (string.IsNullOrWhiteSpace(ErrorMessage))
                    {
                        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Machine</button>
                    }
                    else
                    {
                        <div class="alert alert-danger">@ErrorMessage <a class="btn btn-secondary" data-bs-dismiss="modal">&times; Close</a></div>
                    }
                </div>
            </EditForm>

        </div>
    </div>
</div>

@code {

    [Parameter]
    public EventCallback<AddMachine> OnAddMachine { get; set; }

    private AddMachine model = new();

    public string? ErrorMessage { get; set; }

    private async Task AddMachine()
    {
        try {
            if (OnAddMachine.HasDelegate) {
                await OnAddMachine.InvokeAsync(model);
            }
            await JS.InvokeVoidAsync("hideModal", "addMachineModal");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Kunde inte spara maskinen: {ex.Message}";
        }
    }

    protected override void OnParametersSet()
    {
        model = new AddMachine();
    }
}